# Supabase (required for app + backend)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Backend API base URL. Optional in dev. REQUIRED in production (Rork + Railway).
# Must point to the BACKEND service domain (e.g. Railway backend URL), NOT the frontend.
# No trailing slash. Do not use localhost for production builds.
# Prefer EXPO_PUBLIC_API_URL; EXPO_PUBLIC_API_BASE_URL is also supported.
# EXPO_PUBLIC_API_URL=https://your-backend.up.railway.app
# EXPO_PUBLIC_API_BASE_URL=

# Backend-only (when running backend/server.ts or deploying to Railway)
# PORT=8080
# NODE_ENV=production
# CORS_ORIGIN=https://your-app-origin.com

# Supabase service role (backend only). Required for admin ops (e.g. delete auth user on account deletion, cron). Never expose to the client.
# SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis (optional): rate limiting + response cache (getFeatured, weekly leaderboard). If unset, limits are in-memory and cache is skipped.
# DATABASE_URL / SUPABASE_DB_URL: use Supabase Transaction pooler URL on Railway (host contains pooler, port 6543) — not required for the JS client but useful for logs/migrations.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Optional override for global per-minute cap (default 100).
# RATE_LIMIT_MAX_PER_MIN=
# RevenueCat secret API key (server-side subscription validation). If unset, validation is skipped and current DB values are returned.
# REVENUECAT_API_KEY=

# RevenueCat public API keys (client-side, Expo). Used by react-native-purchases.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
# Prefer RC_* names; REVENUECAT_*_API_KEY aliases are also read in lib/revenue-cat.ts.
EXPO_PUBLIC_RC_IOS_API_KEY=
EXPO_PUBLIC_RC_ANDROID_API_KEY=
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
# EXPO_PUBLIC_REVENUECAT_APPLE_API_KEY=  # alias for iOS
# EXPO_PUBLIC_REVENUECAT_GOOGLE_API_KEY=  # alias for Android

# Sentry (error reporting). If unset, Sentry is not initialized.
# EXPO_PUBLIC_SENTRY_DSN=

# PostHog (analytics). If unset, events are not sent; app works normally.
# EXPO_PUBLIC_POSTHOG_API_KEY=your_posthog_api_key_here
# Set to "true" to send PostHog events from __DEV__ builds (default: off in dev).
# EXPO_PUBLIC_POSTHOG_ENABLE_DEV=false

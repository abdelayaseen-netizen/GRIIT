# Supabase (required for app + backend)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Backend API base URL. Optional in dev. REQUIRED in production (Rork + Railway).
# Must point to the BACKEND service domain (e.g. Railway backend URL), NOT the frontend.
# No trailing slash. Do not use localhost for production builds.
# Prefer EXPO_PUBLIC_API_URL; EXPO_PUBLIC_API_BASE_URL is also supported.
# EXPO_PUBLIC_API_URL=https://your-backend.up.railway.app
# EXPO_PUBLIC_API_BASE_URL=

# Backend-only (when running backend/server.ts or deploying to Railway)
# PORT=8080
# NODE_ENV=production
# CORS_ORIGIN=https://your-app-origin.com
# RevenueCat secret API key (server-side subscription validation). If unset, validation is skipped and current DB values are returned.
# REVENUECAT_API_KEY=

# RevenueCat public API keys (client-side, Expo). Used by react-native-purchases.
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=your_ios_key_here
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=your_android_key_here
# EXPO_PUBLIC_REVENUECAT_APPLE_API_KEY=  # alias for iOS
# EXPO_PUBLIC_REVENUECAT_GOOGLE_API_KEY=  # alias for Android
